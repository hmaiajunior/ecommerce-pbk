# ─── Banco de dados ───────────────────────────────────────────────
# Docker local: usar o valor abaixo
DATABASE_URL="postgresql://postgres:postgres@db:5432/playbekids"

# ─── Redis ────────────────────────────────────────────────────────
# Docker local: usar o valor abaixo
# Produção: URL do Upstash Redis (suporta protocolo Redis padrão)
REDIS_URL="redis://redis:6379"

# ─── Auth.js ──────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET="troque-por-uma-string-segura-gerada-com-openssl"
AUTH_URL="http://localhost:3000"

# ─── InfinitePay ──────────────────────────────────────────────────
# Handle (@) da sua conta InfinitePay, sem o "$" ou "@".
# Encontrado no app InfinitePay, canto superior esquerdo.
INFINITEPAY_HANDLE="sua-infinitetag"

# Segredo (inventado por você) usado como query-param no webhook_url.
# Gerar com: openssl rand -hex 32
# Como a API pública de checkout não assina webhooks, usamos este
# segredo para garantir que a notificação vem mesmo da InfinitePay.
INFINITEPAY_WEBHOOK_SECRET="troque-por-uma-string-segura"

# ─── Melhor Envio ─────────────────────────────────────────────────
MELHOR_ENVIO_TOKEN="seu-token"
MELHOR_ENVIO_SANDBOX="true"
STORE_ZIP="01310100"   # CEP de origem da loja (sem traço)

# ─── Resend (e-mail transacional) ─────────────────────────────────
RESEND_API_KEY="re_xxx"
EMAIL_FROM="noreply@playbekids.com.br"

# ─── Cloudflare R2 (storage de imagens) ───────────────────────────
R2_ACCOUNT_ID="seu-account-id"
R2_ACCESS_KEY_ID="seu-access-key"
R2_SECRET_ACCESS_KEY="seu-secret-key"
R2_BUCKET_NAME="playbekids"
R2_PUBLIC_URL="https://assets.playbekids.com.br"

# ─── App ──────────────────────────────────────────────────────────
# URL pública usada para redirect_url/webhook_url do InfinitePay
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Flags de desenvolvimento ─────────────────────────────────────
# Mostra uma opção de frete grátis "Modo teste" no checkout, permitindo
# fechar pedidos mesmo sem o cálculo de frete real configurado.
# Remova ou use "false" em produção após integrar Melhor Envio.
NEXT_PUBLIC_ALLOW_SKIP_SHIPPING="false"
